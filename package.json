{
  "name": "diaguard-monorepo",
  "version": "1.0.0",
  "description": "DiaguARd - Health monitoring and diagnostic system",
  "private": true,
  "workspaces": [
    "frontend",
    "backend/node"
  ],
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend/node && npm install",
    "install:all": "npm run install:frontend && npm run install:backend",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend/node && npm run dev",
    "dev:django": "cd backend/django && .\\.venv\\Scripts\\python.exe manage.py runserver",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:django\"",
    "build:frontend": "cd frontend && npm run build",
    "start:backend": "cd backend/node && npm start"
  },
  "keywords": [
    "health",
    "monitoring",
    "diagnostic",
    "3d-visualization"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
